t'>\n\t\t\t\t<Headline2>{Title}</Headline2>\n\t\t\t\t<p>{Text}</p>\n\t\t\t</div>\n\t\t\t<div className='CardPic'>\n\t\t\t\t<img src={Image} alt='' />\n\t\t\t</div>\n\t\t</div>\n\t)\n}\n// export const btn = ({className, Text}) => {\n// \treturn (\n// \t\t<button className={className}>{Text}</button>\n// \t)\n// }\n\n// // export const StyledBtn = styled(btn)`\n// \tbackground-color: blue;\n// \twidth: 90px;\n// \theight: 100px;`\n",{"ruleId":"44","severity":1,"message":"45","line":7,"column":4,"nodeType":"46","endLine":7,"endColumn":23},"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement"]